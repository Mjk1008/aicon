# Liara API token (used by GitHub Actions; local CLI uses `liara login` instead).
# Get one from: https://console.liara.ir/profile/api-tokens
# Add it as `LIARA_API_TOKEN` in repo Settings → Secrets → Actions.

LIARA_API_TOKEN=

# Optional overrides for scripts/deploy.sh (defaults match the production app)
APP=aicon
PLATFORM=static
LOCATION=iran
