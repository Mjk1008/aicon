# Arvan Object Storage credentials (used by scripts/deploy.sh and GitHub Actions).
# Get these from: https://panel.arvancloud.ir/storage/access-management
# Never commit the real values — keep them in .env.local (gitignored) or GitHub Secrets.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional overrides (defaults match the production bucket)
BUCKET=aicon-landing
ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
